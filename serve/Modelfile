# NicheLM Ollama Modelfile (stub).
# Build once a GGUF export of the merged checkpoint exists at ./model.gguf:
#   ollama create nichelm -f serve/Modelfile

FROM ./model.gguf

# Llama 3.2 chat template — system / user / assistant turns wrapped in the
# Llama 3 special tokens. See https://www.llama.com/docs/model-cards/llama-3-2/.
TEMPLATE """{{ if .System }}<|start_header_id|>system<|end_header_id|>

{{ .System }}<|eot_id|>{{ end }}{{ if .Prompt }}<|start_header_id|>user<|end_header_id|>

{{ .Prompt }}<|eot_id|>{{ end }}<|start_header_id|>assistant<|end_header_id|>

{{ .Response }}<|eot_id|>"""

SYSTEM """You are a text-to-SQL assistant. Given the schema below, write a single valid SQLite query that answers the user's question. Reply with SQL only, no commentary, no markdown fences."""

PARAMETER temperature 0
PARAMETER top_p 1
PARAMETER num_ctx 4096
PARAMETER stop "<|eot_id|>"
PARAMETER stop "<|end_of_text|>"
