# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Anthropic: required for the Claude Haiku baseline (the only API baseline).
ANTHROPIC_API_KEY=sk-ant-...

# Hugging Face Hub: only needed if you push the trained model card or if
# Spider becomes a gated dataset. The public `xlangai/spider` does not
# require a token at the time of writing.
HF_TOKEN=hf_...

# Weights & Biases: optional. Leave WANDB_API_KEY blank to run offline,
# or `export WANDB_DISABLED=true` to disable entirely.
WANDB_API_KEY=
WANDB_PROJECT=nichelm

# Path the FastAPI server loads the merged model from.
MODEL_PATH=./outputs/nichelm-v1/final
